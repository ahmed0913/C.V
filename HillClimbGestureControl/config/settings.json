{
  "camera": {
    "width": 640,
    "height": 480,
    "fps": 30,
    "camera_id": 0
  },
  "detection": {
    "max_hands": 2,
    "min_detection_confidence": 0.7,
    "min_tracking_confidence": 0.5
  },
  "gesture": {
    "thumb_touch_threshold": 0.03,
    "finger_extension_threshold": 0.01,
    "peace_min_distance": 0.05
  },
  "control": {
    "key_delay": 0.05,
    "flip_frame": true
  },
  "ui": {
    "show_debug_info": true,
    "show_landmarks": true,
    "show_fps": true,
    "font_size": 1.0
  },
  "swipe": {
    "pinch_threshold": 0.05,
    "swipe_threshold": 0.08,
    "swipe_cooldown": 0.4,
    "swipe_distance_pixels": 300
  },
  "performance": {
    "frame_rate_limit": 60,
    "skip_frames": 0
  }
}
